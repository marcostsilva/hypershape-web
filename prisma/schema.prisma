generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GymPlan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

model Gym {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  customDomain   String?        @unique
  
  // Dados Fiscais e Contato
  cnpj           String?        @unique
  corporateName  String?
  tradeName      String?
  address        String?
  ownerEmail     String?
  
  // Gestão de Plano
  plan           GymPlan        @default(FREE)
  studentLimit   Int            @default(10)
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  measurements   Measurement[]
  notifications  Notification[]
  users          User[]
  workouts       Workout[]
}

model User {
  id                    String         @id @default(cuid())
  email                 String         @unique
  password              String?
  name                  String?
  image                 String?
  gymId                 String?
  mode                  Mode           @default(INDEPENDENT)
  role                  Role           @default(SELF)
  tier                  Tier           @default(FREE)
  isBlocked             Boolean        @default(false)
  blockedReason         String?
  blockedAt             DateTime?
  joinedGymAt           DateTime?
  createdAt             DateTime       @default(now())
  emailVerified         DateTime?
  measurementsCreated   Measurement[]  @relation("MeasurementCreator")
  measurements          Measurement[]  @relation("MeasurementOwner")
  notificationsSent     Notification[] @relation("NotificationSender")
  notificationsReceived Notification[] @relation("NotificationReceiver")
  gym                   Gym?           @relation(fields: [gymId], references: [id])
  workoutsCreated       Workout[]      @relation("WorkoutCreator")
  workouts              Workout[]      @relation("WorkoutOwner")
  accounts              Account[]
  sessions              Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workout {
  id              String   @id @default(cuid())
  userId          String
  gymId           String?
  createdById     String?
  name            String
  exercises       Json
  durationMinutes Int?
  caloriesBurned  Float?
  performedAt     DateTime
  createdAt       DateTime @default(now())
  isTemplate      Boolean  @default(false)
  createdBy       User?    @relation("WorkoutCreator", fields: [createdById], references: [id])
  gym             Gym?     @relation(fields: [gymId], references: [id])
  user            User     @relation("WorkoutOwner", fields: [userId], references: [id])
}

model Measurement {
  id           String   @id @default(cuid())
  userId       String
  gymId        String?
  createdById  String?
  weight       Float
  bodyFat      Float?
  measurements Json
  measuredAt   DateTime
  createdAt    DateTime @default(now())
  createdBy    User?    @relation("MeasurementCreator", fields: [createdById], references: [id])
  gym          Gym?     @relation(fields: [gymId], references: [id])
  user         User     @relation("MeasurementOwner", fields: [userId], references: [id])
}

model Notification {
  id       String   @id @default(cuid())
  userId   String
  gymId    String?
  senderId String?
  title    String
  body     String
  isRead   Boolean  @default(false)
  sentAt   DateTime @default(now())
  gym      Gym?     @relation(fields: [gymId], references: [id])
  sender   User?    @relation("NotificationSender", fields: [senderId], references: [id])
  user     User     @relation("NotificationReceiver", fields: [userId], references: [id])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

enum Mode {
  INDEPENDENT
  MANAGED
}

enum Role {
  SELF
  MEMBER
  COACH
  ADMIN
}

enum Tier {
  FREE
  PREMIUM
}

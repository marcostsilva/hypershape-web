generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccessStatus {
  ACTIVE
  FROZEN
  BLOCKED
}

enum PlanTier {
  STARTER
  PRO
  ELITE
  ENTERPRISE
}

enum GlobalRole {
  SUPER_ADMIN
  USER
}

enum Mode {
  INDEPENDENT
  MANAGED
}

enum Role {
  SELF
  MEMBER
  COACH
  ADMIN
}

enum Tier {
  FREE
  PREMIUM
}

model Organization {
  id             String         @id @default(cuid())
  name           String
  slug           String         @unique
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  customDomain   String?        @unique
  
  // Dados Fiscais e Contato
  cnpj           String?        @unique
  corporateName  String?
  tradeName      String?
  street         String?
  number         String?
  complement     String?
  neighborhood   String?
  city           String?
  state          String?
  zipCode        String?
  ownerEmail     String?
  
  // Gestão de Plano
  plan           PlanTier       @default(STARTER)
  maxStudents    Int            @default(50)
  status         AccessStatus   @default(ACTIVE)
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  measurements   Measurement[]
  notifications  Notification[]
  memberships    Membership[]
  workouts       Workout[]

  @@map("gyms")
}

model User {
  id                    String         @id @default(cuid())
  email                 String         @unique
  password              String?
  name                  String?
  image                 String?
  
  // Camada Global
  globalRole            GlobalRole     @default(USER)
  isBlocked             Boolean        @default(false)
  blockedReason         String?
  blockedAt             DateTime?
  
  // LGPD & Consentimento
  acceptedTermsAt       DateTime?
  privacyVersion        String?
  
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  emailVerified         DateTime?
  
  measurementsCreated   Measurement[]  @relation("MeasurementCreator")
  measurements          Measurement[]  @relation("MeasurementOwner")
  notificationsSent     Notification[] @relation("NotificationSender")
  notificationsReceived Notification[] @relation("NotificationReceiver")
  memberships           Membership[]
  workoutsCreated       Workout[]      @relation("WorkoutCreator")
  workouts              Workout[]      @relation("WorkoutOwner")
  accounts              Account[]
  sessions              Session[]
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(MEMBER)
  status         AccessStatus @default(ACTIVE)
  joinedAt       DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  
  @@unique([organizationId, userId])
  @@map("memberships")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workout {
  id              String   @id @default(cuid())
  userId          String
  organizationId  String?
  createdById     String?
  name            String
  exercises       Json
  durationMinutes Int?
  caloriesBurned  Float?
  performedAt     DateTime
  clientSideUuid  String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  isTemplate      Boolean  @default(false)
  createdBy       User?    @relation("WorkoutCreator", fields: [createdById], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])
  user            User     @relation("WorkoutOwner", fields: [userId], references: [id])
}

model Measurement {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  createdById    String?
  weight         Float
  bodyFat        Float?
  measurements   Json
  measuredAt     DateTime
  clientSideUuid String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      User?    @relation("MeasurementCreator", fields: [createdById], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])
  user           User     @relation("MeasurementOwner", fields: [userId], references: [id])
}

model Notification {
  id              String   @id @default(cuid())
  userId          String
  organizationId  String?
  senderId        String?
  title           String
  body            String
  isRead          Boolean  @default(false)
  sentAt          DateTime @default(now())
  updatedAt       DateTime @updatedAt
  organization    Organization? @relation(fields: [organizationId], references: [id])
  sender          User?    @relation("NotificationSender", fields: [senderId], references: [id])
  user            User     @relation("NotificationReceiver", fields: [userId], references: [id])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model AuditLog {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  action         String   // Ex: "student.create", "branding.update", "user.delete"
  targetType     String?  // Ex: "User", "Membership", "Organization"
  targetId       String?  // ID do recurso afetado
  metadata       Json?    // Detalhes adicionais (old/new values, IP, etc.)
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([organizationId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
